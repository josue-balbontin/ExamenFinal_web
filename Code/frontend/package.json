{
  "name": "login-app",
  "version": "1.0.0",
  "description": "Vanilla TS login app with custom Store, Observer & Router",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint src --ext ts",
    "lint:css": "stylelint \"src/**/*.css\"",
    "format": "prettier --write src",
    "validate": "npm run lint && npm run lint:css && npm run build",
    "prepare": "husky",
    "generate-api": "openapi-typescript http://localhost:5181/swagger/v1/swagger.json -o src/types/api.d.ts"
  },
  "devDependencies": {
    "@eslint/js": "^9.5.0",
    "autoprefixer": "^10.4.19",
    "cssnano": "^7.0.3",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-boundaries": "^4.2.1",
    "husky": "^9.0.11",
    "lint-staged": "^15.2.7",
    "openapi-typescript": "^7.13.0",
    "postcss": "^8.4.38",
    "postcss-preset-env": "^9.5.14",
    "prettier": "^3.3.2",
    "stylelint": "^16.6.1",
    "stylelint-config-standard": "^36.0.0",
    "stylelint-order": "^6.0.4",
    "typescript": "^5.4.5",
    "typescript-eslint": "^7.13.1",
    "vite": "^5.3.1"
  },
  "lint-staged": {
    "*.{ts,js}": [
      "eslint --fix",
      "prettier --write --ignore-unknown"
    ],
    "*.css": [
      "stylelint --fix",
      "prettier --write --ignore-unknown"
    ]
  },
  "dependencies": {
    "openapi-fetch": "^0.17.0"
  }
}
